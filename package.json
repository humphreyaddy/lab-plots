{
  "name": "lab-plots",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-only data visualisation studio: phylogenetic trees, heatmaps, sankey diagrams from a metadata sheet.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chroma-js": "^2.4.2",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.469.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/chroma-js": "^2.4.5",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.6",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.6"
  }
}
